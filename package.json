{
  "name": "software-citation-station",
  "version": "1.0.0",
  "description": "Software citation station with Zenodo version caching",
  "type": "module",
  "bin": {
    "scs": "./dist/cli/index.js"
  },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "build": "tsc",
    "fetch-versions": "node dist/fetchVersions.js",
    "scs": "node dist/cli/index.js"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/semver": "^7.7.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "extensionsToTreatAsEsm": [".ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}\/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.test.[jt]s"
    ]
  },
  "dependencies": {
    "commander": "^11.1.0",
    "semver": "^7.7.3"
  }
}
