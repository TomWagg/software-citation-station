{
  "name": "software-citation-station",
  "version": "1.0.0",
  "description": "Software citation station with Zenodo version caching",
  "bin": {
    "scs": "dist/cli.js"
  },
  "scripts": {
    "test": "jest",
    "test:e2e": "playwright test",
    "build": "tsc",
    "build:frontend": "tsc -p tsconfig.frontend.json && node scripts/bundle-frontend.js",
    "build:timestamp": "node scripts/generate-timestamp.js",
    "build:all": "npm run build && npm run build:frontend && npm run build:timestamp",
    "fetch-versions": "node dist/fetchVersions.js",
    "cli": "node dist/cli.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/semver": "^7.7.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "!**/__tests__/e2e/**/*.test.ts"
    ]
  },
  "dependencies": {
    "semver": "^7.7.3"
  }
}
